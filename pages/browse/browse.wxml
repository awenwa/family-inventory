<!-- pages/browse/browse.wxml -->
<view class="page">
  <!-- 分类标签栏 + 管理入口 -->
  <view class="cat-bar-wrap">
    <view class="cat-bar">
      <scroll-view scroll-x class="cat-scroll" scroll-into-view="cat-{{activeCat}}" scroll-with-animation>
        <view
          wx:for="{{categories}}"
          wx:key="id"
          id="cat-{{item.id}}"
          class="cat-tab {{activeCat === item.id ? 'active' : ''}}"
          style="{{activeCat === item.id ? 'background:' + item.color + ';color:#fff;border-color:' + item.color : ''}}"
          bindtap="switchCat"
          data-id="{{item.id}}"
        >
          <text>{{item.icon}}</text>
          <text class="tab-name">{{item.name}}</text>
        </view>
      </scroll-view>
    </view>
    <view class="manage-btn" bindtap="goManage">
      <text>管理</text>
    </view>
  </view>

  <!-- 物品列表 -->
  <view class="list-area">
    <!-- 排序工具栏 -->
    <view class="toolbar">
      <text class="toolbar-count">{{displayItems.length}} 件物品</text>
      <view class="sort-group">
        <text class="sort-label">排序:</text>
        <text 
          wx:for="{{sortOptions}}" 
          wx:key="key"
          class="sort-btn {{sortKey === item.key ? 'sort-active' : ''}}"
          bindtap="setSort"
          data-key="{{item.key}}"
        >{{item.label}}</text>
      </view>
    </view>

    <!-- 瀑布流网格 -->
    <view wx:if="{{displayItems.length > 0}}" class="grid">
      <view 
        wx:for="{{displayItems}}" 
        wx:key="id"
        class="grid-item"
        bindtap="goDetail"
        data-id="{{item.id}}"
      >
        <view class="card">
          <view class="card-top" style="background:{{item.category_color}}18">
            <text class="card-emoji">{{item.category_icon}}</text>
            <view class="card-tags">
              <text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="{{tag}}" class="tag">{{tag}}</text>
            </view>
          </view>
          <view class="card-body">
            <text class="card-name">{{item.name}}</text>
            <view class="card-meta">
              <text class="card-color">{{item.specs.color || ''}}</text>
              <text class="card-dot" wx:if="{{item.specs.color && item.specs.model}}">·</text>
              <text class="card-model">{{item.specs.model || ''}}</text>
            </view>
            <view class="card-footer">
              <text class="card-price">¥{{item.price_str}}</text>
              <text class="card-date">{{item.dateDiff}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:else class="empty">
      <text class="empty-icon">📭</text>
      <text class="empty-t">该分类下暂无物品</text>
      <text class="empty-sub">点击右下角按钮添加</text>
    </view>
  </view>

  <!-- FAB -->
  <view class="fab" bindtap="goAdd">
    <text class="fab-plus">+</text>
  </view>
</view>
