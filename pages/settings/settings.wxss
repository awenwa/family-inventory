/* pages/settings/settings.wxss */
page { background: #FAFAF7; }
.page { min-height: 100vh; padding-bottom: 40rpx; }

.stat-overview {
  background: linear-gradient(135deg, #3D7A5C, #5A9A7A);
  margin: 24rpx;
  border-radius: 24rpx;
  padding: 36rpx;
}

.stat-title {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  font-weight: 600;
  margin-bottom: 24rpx;
}

.stat-grid {
  display: flex;
  gap: 1rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 16rpx;
  overflow: hidden;
}

.stat-cell {
  flex: 1;
  background: rgba(255,255,255,0.15);
  padding: 24rpx 16rpx;
  text-align: center;
}

.stat-n {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 8rpx;
  line-height: 1;
}

.stat-k {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.65);
}

.section { margin: 0 24rpx 32rpx; }

.sec-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A18;
  margin-bottom: 20rpx;
}

.cat-stats {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.cat-stat-row {
  display: flex;
  align-items: center;
  padding: 22rpx 28rpx;
  border-bottom: 1rpx solid #F5F3EE;
  gap: 16rpx;
}

.cat-stat-row:last-child { border-bottom: none; }

.cs-icon { font-size: 28rpx; flex-shrink: 0; width: 40rpx; text-align: center; }

.cs-name { font-size: 26rpx; color: #3A3A30; width: 120rpx; flex-shrink: 0; }

.cs-bar-wrap {
  flex: 1;
  background: #F0EDE6;
  border-radius: 100rpx;
  height: 12rpx;
  overflow: hidden;
}

.cs-bar {
  display: block;
  height: 100%;
  border-radius: 100rpx;
  min-width: 6rpx;
}

.cs-count {
  font-size: 26rpx;
  font-weight: 700;
  color: #1A1A18;
  width: 40rpx;
  text-align: right;
  flex-shrink: 0;
}

.action-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.action-item {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid #F5F3EE;
  gap: 20rpx;
}

.action-item:last-child { border-bottom: none; }

.action-item.danger .ai-name { color: #E05050; }

.ai-icon { font-size: 36rpx; flex-shrink: 0; width: 48rpx; text-align: center; }

.ai-body { flex: 1; }

.ai-name { display: block; font-size: 30rpx; font-weight: 600; color: #1A1A18; margin-bottom: 6rpx; }

.ai-sub { display: block; font-size: 24rpx; color: #9E9E8A; }

.ai-arrow { font-size: 32rpx; color: #C8C4B8; flex-shrink: 0; }

.about-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.about-name { display: block; font-size: 32rpx; font-weight: 700; color: #1A1A18; margin-bottom: 8rpx; }

.about-ver { display: block; font-size: 24rpx; color: #9E9E8A; margin-bottom: 16rpx; }

.about-desc { display: block; font-size: 26rpx; color: #7A7A6A; line-height: 1.8; }

/* 云同步 */
.cloud-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.cloud-status {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.cloud-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.cloud-dot.online {
  background: #3D7A5C;
  box-shadow: 0 0 8rpx rgba(61,122,92,0.5);
}

.cloud-dot.offline {
  background: #D0CCC0;
}

.cloud-status-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A18;
}

.cloud-sync-time {
  font-size: 22rpx;
  color: #9E9E8A;
  margin-left: auto;
}

.cloud-env-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.cloud-env-label {
  font-size: 26rpx;
  color: #6A6A5A;
  flex-shrink: 0;
  white-space: nowrap;
}

.cloud-env-value {
  flex: 1;
  font-size: 24rpx;
  color: #1A1A18;
  font-family: 'Menlo', monospace;
  word-break: break-all;
}

.cloud-env-badge {
  font-size: 22rpx;
  color: #fff;
  background: #3D7A5C;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  margin-left: 8rpx;
}

.cloud-env-input {
  flex: 1;
  background: #FAFAF7;
  border: 1rpx solid #E0DDD5;
  border-radius: 12rpx;
  padding: 14rpx 18rpx;
  font-size: 26rpx;
  color: #1A1A18;
  height: 64rpx;
  box-sizing: border-box;
}

.cloud-actions {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.cloud-btn {
  flex: 1;
  padding: 18rpx 0;
  text-align: center;
  border-radius: 100rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.2s;
}

.cloud-btn.primary {
  background: linear-gradient(135deg, #3D7A5C, #5A9A7A);
  color: #fff;
}

.cloud-btn.outline {
  border: 1rpx solid #3D7A5C;
  color: #3D7A5C;
  background: #fff;
}

.cloud-btn.disabled {
  background: #E8E5DC;
  color: #9E9E8A;
}

.cloud-hint {
  background: #FFF8E6;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
}

.cloud-hint-text {
  font-size: 22rpx;
  color: #C88A2C;
  line-height: 1.6;
}

.cloud-disconnect {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #E05050;
  padding: 12rpx 0;
}
